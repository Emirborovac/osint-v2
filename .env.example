# --- LLM (synthesis step) ---
LLM_API_KEY=

# --- Google Custom Search API (preferred over scraping; falls back to scraper if unset) ---
# API key: Cloud Console -> enable "Custom Search API" -> create API key
# CSE id:  programmablesearchengine.google.com -> new engine -> "Search entire web" ON
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- free-tier API keys (optional, raise quotas) ---
